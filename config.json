  "tcid_format": "TC-{seq:03d}",
  "global_metadata_keys": [
    "URL Target",
    "Modul",
    "Tanggal Dibuat",
    "Author",
    "Tiket Story Dev",
    "Tiket Test Case",
    "Platform",
    "Env",
    "Username",
    "Password"
