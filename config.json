    {"id": "test_data", "name": "Test Data", "width": 20, "visible": true, "order": 7},
    {"id": "expected_result", "name": "Expected Results", "width": 50, "visible": true, "order": 8},
    {"id": "actual_results", "name": "Actual Results", "width": 30, "visible": true, "order": 9},
    {"id": "status", "name": "Status", "width": 15, "visible": true, "order": 10},
    {"id": "link_evidence", "name": "Link Evidence", "width": 20, "visible": true, "order": 11},
    {"id": "remarks", "name": "Remarks", "width": 20, "visible": true, "order": 12}
