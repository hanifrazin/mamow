    {"id": "priority", "name": "Priority", "width": 10, "visible": true, "order": 3},
    {"id": "scenario", "name": "Scenario", "width": 40, "visible": true, "order": 4},
    {"id": "precondition", "name": "Pre-Condition", "width": 30, "visible": true, "order": 5},
